<!DOCTYPE html>

<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>7桁ハンター / YouTube</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Noto+Sans+JP:wght@300;400;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0c0c0c;
  --surface: #141414;
  --card: #1a1a1a;
  --border: #2a2a2a;
  --red: #ff0000;
  --red-dim: rgba(255,0,0,0.15);
  --red-glow: rgba(255,0,0,0.25);
  --gold: #ffc107;
  --gold-dim: rgba(255,193,7,0.12);
  --text: #f0f0f0;
  --muted: #666;
}

- { margin:0; padding:0; box-sizing:border-box; }

body {
background: var(–bg);
color: var(–text);
font-family: ‘Noto Sans JP’, sans-serif;
min-height: 100vh;
}

/* scanline effect */
body::after {
content:’’;
position:fixed;
inset:0;
background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.03) 2px, rgba(0,0,0,0.03) 4px);
pointer-events:none;
z-index:9999;
}

.wrap { max-width: 860px; margin: 0 auto; padding: 40px 20px; }

/* Header */
header { margin-bottom: 40px; }

.logo {
display: flex;
align-items: baseline;
gap: 14px;
margin-bottom: 6px;
}

.logo-text {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 72px;
line-height: 1;
color: var(–text);
letter-spacing: 2px;
}

.logo-yt {
background: var(–red);
color: white;
font-family: ‘Bebas Neue’, sans-serif;
font-size: 18px;
letter-spacing: 2px;
padding: 4px 10px;
border-radius: 4px;
}

.tagline {
font-size: 11px;
letter-spacing: 4px;
color: var(–muted);
text-transform: uppercase;
margin-left: 2px;
}

/* Panel */
.panel {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 12px;
padding: 24px;
margin-bottom: 20px;
}

.panel-title {
font-size: 10px;
letter-spacing: 3px;
text-transform: uppercase;
color: var(–muted);
margin-bottom: 16px;
}

/* API key input */
.input-row {
display: flex;
gap: 10px;
margin-bottom: 14px;
}

input[type=“text”], input[type=“password”], input[type=“number”] {
background: var(–bg);
border: 1px solid var(–border);
border-radius: 8px;
color: var(–text);
font-family: ‘JetBrains Mono’, monospace;
font-size: 13px;
padding: 10px 14px;
outline: none;
transition: border-color 0.2s;
width: 100%;
}

input:focus { border-color: var(–red); box-shadow: 0 0 0 2px var(–red-dim); }
input::placeholder { color: var(–muted); }

.toggle-vis {
background: var(–card);
border: 1px solid var(–border);
border-radius: 8px;
color: var(–muted);
cursor: pointer;
padding: 10px 14px;
font-size: 16px;
flex-shrink: 0;
transition: color 0.2s;
}
.toggle-vis:hover { color: var(–text); }

/* Settings row */
.settings-row {
display: flex;
gap: 12px;
flex-wrap: wrap;
}

.setting-group {
display: flex;
flex-direction: column;
gap: 5px;
flex: 1;
min-width: 120px;
}

.setting-label {
font-size: 10px;
letter-spacing: 2px;
text-transform: uppercase;
color: var(–muted);
}

input[type=“number”] { width: 100%; }

/* Run button */
.run-btn {
width: 100%;
padding: 14px;
margin-top: 20px;
background: var(–red);
border: none;
border-radius: 8px;
color: white;
font-family: ‘Bebas Neue’, sans-serif;
font-size: 22px;
letter-spacing: 3px;
cursor: pointer;
transition: all 0.2s;
position: relative;
overflow: hidden;
}

.run-btn:hover { background: #cc0000; box-shadow: 0 6px 24px var(–red-glow); transform: translateY(-1px); }
.run-btn:active { transform: translateY(0); }
.run-btn:disabled { background: #333; color: #666; cursor: not-allowed; transform: none; box-shadow: none; }

/* Progress */
.progress-box {
display: none;
background: var(–card);
border: 1px solid var(–border);
border-radius: 12px;
padding: 20px;
margin-bottom: 20px;
}

.progress-box.visible { display: block; }

.progress-bar-wrap {
background: var(–border);
border-radius: 4px;
height: 4px;
margin-bottom: 12px;
overflow: hidden;
}

.progress-bar {
height: 100%;
background: var(–red);
border-radius: 4px;
width: 0%;
transition: width 0.3s;
box-shadow: 0 0 8px var(–red-glow);
}

.log-area {
font-family: ‘JetBrains Mono’, monospace;
font-size: 11px;
color: var(–muted);
max-height: 120px;
overflow-y: auto;
line-height: 1.8;
}

.log-area .log-ok { color: #4caf50; }
.log-area .log-hit { color: var(–gold); }
.log-area .log-err { color: #f44336; }

/* Stats */
.stats-row {
display: grid;
grid-template-columns: repeat(4, 1fr);
gap: 1px;
background: var(–border);
border: 1px solid var(–border);
border-radius: 10px;
overflow: hidden;
margin-bottom: 20px;
}

.stat-box {
background: var(–card);
padding: 16px;
text-align: center;
}

.stat-val {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 32px;
color: var(–red);
line-height: 1;
}

.stat-lbl {
font-size: 9px;
letter-spacing: 2px;
color: var(–muted);
text-transform: uppercase;
margin-top: 3px;
}

/* Controls */
.ctrl-row {
display: flex;
gap: 8px;
margin-bottom: 16px;
align-items: center;
flex-wrap: wrap;
}

.filter-btn {
padding: 6px 14px;
border-radius: 6px;
font-size: 12px;
cursor: pointer;
border: 1px solid var(–border);
background: var(–surface);
color: var(–muted);
font-family: ‘Noto Sans JP’, sans-serif;
transition: all 0.15s;
}

.filter-btn.active {
background: var(–red-dim);
border-color: var(–red);
color: var(–red);
}

.csv-btn {
margin-left: auto;
padding: 6px 16px;
border-radius: 6px;
font-size: 12px;
cursor: pointer;
border: 1px solid var(–border);
background: var(–surface);
color: var(–muted);
font-family: ‘Noto Sans JP’, sans-serif;
transition: all 0.15s;
}
.csv-btn:hover { color: var(–text); border-color: #555; }

/* Results */
.results-wrap { display: none; }
.results-wrap.visible { display: block; }

.result-card {
background: var(–card);
border: 1px solid var(–border);
border-radius: 10px;
padding: 18px;
margin-bottom: 8px;
animation: fadeUp 0.3s ease both;
transition: border-color 0.2s;
position: relative;
}

@keyframes fadeUp {
from { opacity:0; transform: translateY(6px); }
to { opacity:1; transform: translateY(0); }
}

.result-card:hover { border-color: #3a3a3a; }

.card-header {
display: flex;
gap: 12px;
align-items: flex-start;
margin-bottom: 10px;
}

.source-badge {
font-size: 10px;
letter-spacing: 1px;
text-transform: uppercase;
padding: 3px 8px;
border-radius: 4px;
flex-shrink: 0;
font-weight: 700;
}

.source-badge.desc {
background: rgba(33,150,243,0.15);
color: #64b5f6;
border: 1px solid rgba(33,150,243,0.3);
}

.source-badge.comment {
background: rgba(76,175,80,0.15);
color: #81c784;
border: 1px solid rgba(76,175,80,0.3);
}

.card-title {
font-size: 13px;
color: var(–muted);
flex: 1;
line-height: 1.4;
}

.card-title a {
color: #aaa;
text-decoration: none;
}
.card-title a:hover { color: var(–text); }

.card-text {
font-size: 13px;
line-height: 1.7;
color: #ccc;
margin-bottom: 10px;
word-break: break-all;
}

.card-text .hl {
font-family: ‘JetBrains Mono’, monospace;
font-weight: 700;
font-size: 14px;
color: var(–gold);
background: var(–gold-dim);
padding: 1px 5px;
border-radius: 4px;
border: 1px solid rgba(255,193,7,0.2);
}

.card-footer {
display: flex;
gap: 12px;
align-items: center;
flex-wrap: wrap;
}

.num-tag {
font-family: ‘JetBrains Mono’, monospace;
font-size: 12px;
background: var(–gold-dim);
border: 1px solid rgba(255,193,7,0.25);
color: var(–gold);
padding: 3px 10px;
border-radius: 20px;
}

.likes-info {
margin-left: auto;
font-size: 12px;
color: var(–muted);
display: flex;
align-items: center;
gap: 4px;
}

/* Empty */
.empty {
text-align: center;
padding: 60px 20px;
color: var(–muted);
font-size: 14px;
line-height: 2;
}

@media (max-width: 600px) {
.logo-text { font-size: 48px; }
.stats-row { grid-template-columns: repeat(2,1fr); }
.settings-row { flex-direction: column; }
}
</style>

</head>
<body>
<div class="wrap">

<header>
  <div class="logo">
    <span class="logo-text">7桁ハンター</span>
    <span class="logo-yt">YouTube</span>
  </div>
  <div class="tagline">概要欄・コメントから数字を自動収集</div>
</header>

<!-- 設定パネル -->

<div class="panel">
  <div class="panel-title">設定</div>

  <div style="margin-bottom:14px;">
    <div class="setting-label" style="margin-bottom:6px;">YouTube API キー</div>
    <div class="input-row">
      <input type="password" id="apiKey" placeholder="AIza...">
      <button class="toggle-vis" onclick="toggleKey()">👁</button>
    </div>
  </div>

  <div style="margin-bottom:0;">
    <div class="setting-label" style="margin-bottom:6px;">検索キーワード <span style="color:#555;font-size:10px;letter-spacing:0">（複数は改行して入力）</span></div>
    <textarea id="searchQuery" rows="3" placeholder="例：&#10;懸賞 当選番号&#10;ロト7 結果" style="width:100%;background:var(--bg);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:'Noto Sans JP',sans-serif;font-size:13px;padding:10px 14px;outline:none;resize:vertical;margin-bottom:14px;line-height:1.8;"></textarea>
  </div>

  <div class="settings-row">
    <div class="setting-group">
      <span class="setting-label">桁数</span>
      <input type="number" id="digitCount" value="7" min="1" max="15">
    </div>
    <div class="setting-group">
      <span class="setting-label">最大動画数</span>
      <input type="number" id="maxVideos" value="10" min="1" max="50">
    </div>
    <div class="setting-group">
      <span class="setting-label">コメント数/動画</span>
      <input type="number" id="maxComments" value="100" min="10" max="500">
    </div>
  </div>

<button class="run-btn" id="runBtn" onclick="startHunt()">▶ 収集スタート</button>

</div>

<!-- プログレス -->

<div class="progress-box" id="progressBox">
  <div class="progress-bar-wrap"><div class="progress-bar" id="progressBar"></div></div>
  <div class="log-area" id="logArea"></div>
</div>

<!-- 結果 -->

<div class="results-wrap" id="resultsWrap">
  <div class="stats-row" id="statsRow"></div>

  <div class="ctrl-row">
    <span style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--muted)">表示</span>
    <button class="filter-btn active" id="filterAll" onclick="filterResults('all')">すべて</button>
    <button class="filter-btn" id="filterDesc" onclick="filterResults('desc')">📄 概要欄</button>
    <button class="filter-btn" id="filterComment" onclick="filterResults('comment')">💬 コメント</button>
    <button class="csv-btn" onclick="downloadCSV()">⬇ CSV保存</button>
  </div>

  <div id="resultsList"></div>
</div>

</div>

<script>
const BASE = 'https://www.googleapis.com/youtube/v3';
let allResults = [];
let currentFilter = 'all';

function toggleKey() {
  const inp = document.getElementById('apiKey');
  inp.type = inp.type === 'password' ? 'text' : 'password';
}

function log(msg, type = '') {
  const area = document.getElementById('logArea');
  const line = document.createElement('div');
  if (type) line.className = `log-${type}`;
  line.textContent = msg;
  area.appendChild(line);
  area.scrollTop = area.scrollHeight;
}

function setProgress(pct) {
  document.getElementById('progressBar').style.width = pct + '%';
}

function extractNumbers(text, digits) {
  const re = new RegExp(`(?<!\\d)\\d{${digits}}(?!\\d)`, 'g');
  return [...text.matchAll(re)].map(m => m[0]);
}

function highlightNumbers(text, digits) {
  const safe = text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  const re = new RegExp(`(?<!\\d)(\\d{${digits}})(?!\\d)`, 'g');
  return safe.replace(re, '<span class="hl">$1</span>');
}

async function apiFetch(endpoint, params) {
  const apiKey = document.getElementById('apiKey').value.trim();
  const qs = new URLSearchParams({ key: apiKey, ...params }).toString();
  const res = await fetch(`${BASE}/${endpoint}?${qs}`);
  if (!res.ok) {
    const err = await res.json();
    throw new Error(err.error?.message || res.statusText);
  }
  return res.json();
}

async function searchVideos(query, maxVideos) {
  const data = await apiFetch('search', {
    q: query, part: 'snippet', type: 'video',
    maxResults: Math.min(50, maxVideos), relevanceLanguage: 'ja'
  });
  return data.items.filter(i => i.id.videoId).slice(0, maxVideos);
}

async function getDescription(videoId) {
  const data = await apiFetch('videos', { id: videoId, part: 'snippet' });
  return data.items[0]?.snippet?.description || '';
}

async function getComments(videoId, maxComments) {
  const comments = [];
  let pageToken = null;
  try {
    while (comments.length < maxComments) {
      const params = { videoId, part: 'snippet', maxResults: Math.min(100, maxComments - comments.length), order: 'relevance' };
      if (pageToken) params.pageToken = pageToken;
      const data = await apiFetch('commentThreads', params);
      for (const item of data.items) {
        const s = item.snippet.topLevelComment.snippet;
        comments.push({ text: s.textDisplay || '', likes: s.likeCount || 0 });
      }
      pageToken = data.nextPageToken;
      if (!pageToken) break;
    }
  } catch(e) {
    // コメント無効など
  }
  return comments;
}

async function startHunt() {
  const apiKey = document.getElementById('apiKey').value.trim();
  const queries = document.getElementById('searchQuery').value.trim().split('\n').map(q => q.trim()).filter(q => q);
  const digits = parseInt(document.getElementById('digitCount').value) || 7;
  const maxVideos = parseInt(document.getElementById('maxVideos').value) || 10;
  const maxComments = parseInt(document.getElementById('maxComments').value) || 100;

  if (!apiKey) { alert('APIキーを入力してください'); return; }
  if (!queries.length) { alert('検索キーワードを入力してください'); return; }

  allResults = [];
  document.getElementById('runBtn').disabled = true;
  document.getElementById('progressBox').classList.add('visible');
  document.getElementById('resultsWrap').classList.remove('visible');
  document.getElementById('logArea').innerHTML = '';
  setProgress(0);

  try {
    // 複数キーワードの動画をまとめて収集（重複除去）
    const seenIds = new Set();
    const allVideos = [];
    for (const query of queries) {
      log(`🔍 「${query}」で検索中...`);
      const vids = await searchVideos(query, maxVideos);
      for (const v of vids) {
        if (!seenIds.has(v.id.videoId)) {
          seenIds.add(v.id.videoId);
          allVideos.push(v);
        }
      }
      log(`  → ${vids.length}件発見`, 'ok');
    }
    const videos = allVideos;
    log(`✅ 合計 ${videos.length}件の動画を収集（重複除去済み）`, 'ok');

    for (let i = 0; i < videos.length; i++) {
      const video = videos[i];
      const videoId = video.id.videoId;
      const title = video.snippet.title;
      const url = `https://www.youtube.com/watch?v=${videoId}`;
      setProgress(Math.round((i / videos.length) * 100));

      log(`[${i+1}/${videos.length}] ${title.slice(0,40)}...`);

      // 概要欄
      const desc = await getDescription(videoId);
      const descNums = extractNumbers(desc, digits);
      if (descNums.length > 0) {
        log(`  📄 概要欄: ${descNums.join(', ')}`, 'hit');
        allResults.push({ source: 'desc', url, title, text: desc.slice(0,300), numbers: descNums, likes: null });
      }

      // コメント
      const comments = await getComments(videoId, maxComments);
      let hitCount = 0;
      for (const c of comments) {
        const nums = extractNumbers(c.text, digits);
        if (nums.length > 0) {
          hitCount++;
          allResults.push({ source: 'comment', url, title, text: c.text.slice(0,300), numbers: nums, likes: c.likes });
        }
      }
      if (hitCount > 0) log(`  💬 コメント ${hitCount}件ヒット`, 'hit');

      await new Promise(r => setTimeout(r, 200));
    }

    setProgress(100);
    log(`\n🏆 完了！合計 ${allResults.length} 件のヒット`, 'ok');
    renderResults();

  } catch(e) {
    log(`❌ エラー: ${e.message}`, 'err');
  } finally {
    document.getElementById('runBtn').disabled = false;
  }
}

function renderResults() {
  const wrap = document.getElementById('resultsWrap');
  const list = document.getElementById('resultsList');
  const digits = parseInt(document.getElementById('digitCount').value) || 7;
  wrap.classList.add('visible');

  const filtered = currentFilter === 'all' ? allResults
    : allResults.filter(r => r.source === currentFilter);

  // ソート（いいね数順、概要欄は上位）
  const sorted = [...filtered].sort((a,b) => {
    if (a.source === 'desc' && b.source !== 'desc') return -1;
    if (b.source === 'desc' && a.source !== 'desc') return 1;
    return (b.likes || 0) - (a.likes || 0);
  });

  // stats
  const totalDesc = allResults.filter(r => r.source === 'desc').length;
  const totalComment = allResults.filter(r => r.source === 'comment').length;
  const allNums = [...new Set(allResults.flatMap(r => r.numbers))];
  document.getElementById('statsRow').innerHTML = `
    <div class="stat-box"><div class="stat-val">${allResults.length}</div><div class="stat-lbl">総ヒット</div></div>
    <div class="stat-box"><div class="stat-val">${totalDesc}</div><div class="stat-lbl">概要欄</div></div>
    <div class="stat-box"><div class="stat-val">${totalComment}</div><div class="stat-lbl">コメント</div></div>
    <div class="stat-box"><div class="stat-val">${allNums.length}</div><div class="stat-lbl">ユニーク数字</div></div>
  `;

  if (sorted.length === 0) {
    list.innerHTML = `<div class="empty">該当する${digits}桁の数字が見つかりませんでした。<br>キーワードや桁数を変えて試してみてください。</div>`;
    return;
  }

  list.innerHTML = sorted.map((r, i) => `
    <div class="result-card" style="animation-delay:${i*0.03}s">
      <div class="card-header">
        <span class="source-badge ${r.source === 'desc' ? 'desc' : 'comment'}">${r.source === 'desc' ? '📄 概要欄' : '💬 コメント'}</span>
        <div class="card-title"><a href="${r.url}" target="_blank">${r.title}</a></div>
      </div>
      <div class="card-text">${highlightNumbers(r.text, digits)}</div>
      <div class="card-footer">
        ${r.numbers.map(n => `<span class="num-tag">${n}</span>`).join('')}
        ${r.likes !== null ? `<div class="likes-info">👍 ${Number(r.likes).toLocaleString()}</div>` : ''}
      </div>
    </div>
  `).join('');
}

function filterResults(type) {
  currentFilter = type;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  document.getElementById(`filter${type.charAt(0).toUpperCase()+type.slice(1)}`).classList.add('active');
  renderResults();
}

function downloadCSV() {
  if (!allResults.length) return;
  const headers = ['ソース','動画URL','タイトル','テキスト','数字','いいね数'];
  const rows = allResults.map(r => [
    r.source === 'desc' ? '概要欄' : 'コメント',
    r.url, r.title,
    r.text.replace(/"/g,'""'),
    r.numbers.join(', '),
    r.likes ?? ''
  ]);
  const csv = [headers, ...rows].map(r => r.map(v => `"${v}"`).join(',')).join('\n');
  const blob = new Blob(['\uFEFF'+csv], {type:'text/csv;charset=utf-8'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `youtube_hunter_${new Date().toISOString().slice(0,10)}.csv`;
  a.click();
}
</script>

</body>
</html>
